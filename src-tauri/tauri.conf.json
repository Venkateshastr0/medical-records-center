{
  "$schema": "https://schema.tauri.app/config/1.0.0",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../src-next",
    "distDir": "../src-next/out",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "Medical Records Center",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "fs": {
        "all": false,
        "readFile": true,
        "writeFile": true,
        "readDir": false,
        "writeDir": false,
        "copyFile": false,
        "createDir": true,
        "removeDir": false,
        "renameFile": false,
        "copyDir": false,
        "scope": ["$APPDATA/uploads/**", "$RESOURCE/uploads/**", "$APPDATA/medical_records.db", "$RESOURCE/medical_records.db"]
      },
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": false,
        "ask": true,
        "confirm": true,
        "message": true,
        "open": true,
        "save": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.mrc.medical",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [
        "resources/*"
      ]
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Medical Records Center",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768
      }
    ],
    "macOSPrivateApi": false
  },
  "plugins": {}
}
